{
  "name": "docker-learning-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.js && vite build && node scripts/prerender.js && node scripts/copy-static-pages.js",
    "generate-favicons": "node scripts/generate-favicons.js",
    "preview": "npm run build && wrangler dev",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "mermaid": "^11.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "puppeteer": "^21.3.8",
    "vite": "^6.0.0",
    "wrangler": "^4.90.0"
  }
}
